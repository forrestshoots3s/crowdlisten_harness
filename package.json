{
  "name": "@crowdlisten/kanban",
  "version": "0.3.0",
  "description": "Planning and task delegation for AI agents — decompose specs into executable work, route to coding agents with project context intact",
  "type": "module",
  "bin": {
    "crowdlisten-kanban": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@supabase/supabase-js": "^2.49.4"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "kanban",
    "coding-agent",
    "crowdlisten",
    "vibe-kanban"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Crowdlisten/crowdlisten_tasks.git"
  },
  "homepage": "https://crowdlisten.com"
}
