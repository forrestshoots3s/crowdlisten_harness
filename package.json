{
  "name": "@crowdlisten/planner",
  "version": "0.4.0",
  "description": "Planning and delegation system for AI agents — plan before you build, capture knowledge as you go, compound learnings across tasks",
  "type": "module",
  "bin": {
    "crowdlisten-planner": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@supabase/supabase-js": "^2.49.4"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "planning",
    "delegation",
    "coding-agent",
    "crowdlisten",
    "knowledge-base"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Crowdlisten/crowdlisten_tasks.git"
  },
  "homepage": "https://crowdlisten.com"
}
